{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/**/*.py": {
      "maxDuration": 300,
      "includeFiles": "ontorag_mcp/**"
    }
  },
  "rewrites": [
    { "source": "/mcp", "destination": "/api/index" },
    { "source": "/mcp/(.*)", "destination": "/api/index" }
  ]
}
